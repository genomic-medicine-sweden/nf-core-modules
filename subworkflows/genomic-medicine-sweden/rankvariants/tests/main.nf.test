nextflow_workflow {

    name "Test Workflow RANK_VARIANTS"
    script "../main.nf"
    config "./nextflow.config"
    workflow "RANK_VARIANTS"
    tag "subworkflows"
    tag "subworkflows_genomic_medicine_sweden"
    tag "subworkflows/rankvariants"
    tag "genmod"
    tag "genmod/annotate"
    tag "genmod/models"
    tag "genmod/score"
    tag "genmod/compound"
    tag "bcftools"
    tag "bcftools/view"

    setup {
        nfcoreInitialise("${launchDir}/library/")
        nfcoreInstall(
            "${launchDir}/library/",
            [
                "genmod/annotate",
                "genmod/models",
                "genmod/score",
                "genmod/compound",
                "bcftools/view",
            ]
        )
        nfcoreLink("${launchDir}/library/", "${baseDir}/modules/")
    }

    test("All genmod modules") {

        when {
            workflow {
                """
                input[0] = channel.of([
                    [ id:'test'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/vcf/genmod.vcf.gz', checkIfExists: true)
                ])
                input[1] = channel.of([
                    [ id:'test'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/vcf/ped/justhusky.ped', checkIfExists: true)
                ])
                input[2] = channel.of([
                    [ id: 'genmod_reduced_penetrance' ],
                    []
                ])
                input[3] = channel.of([
                    [ id: 'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/genmod/svrank_model_-v1.8-.ini', checkIfExists: true)
                ])
                input[4] = false
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.trace.sucessed().size() == 5 }, 
                { assert snapshot(
                    file(workflow.out.index.get(0).get(1)).name,
                    path(workflow.out.vcf.get(0).get(1)).vcf.variantsMD5
                ).match() }
            )
        }

        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
        }
    }

test("Genmod score only") {

        when {
            workflow {
                """
                input[0] = channel.of([
                    [ id:'test'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/vcf/genmod.vcf.gz', checkIfExists: true)
                ])
                input[1] = channel.of([
                    [ id:'test'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/vcf/ped/justhusky.ped', checkIfExists: true)
                ])
                input[2] = channel.of([
                    [ id: 'genmod_reduced_penetrance' ],
                    []
                ])
                input[3] = channel.of([
                    [ id: 'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/genmod/svrank_model_-v1.8-.ini', checkIfExists: true)
                ])
                input[4] = true
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.trace.sucessed().size() == 2 },
                { assert snapshot(
                    file(workflow.out.index.get(0).get(1)).name,
                    path(workflow.out.vcf.get(0).get(1)).vcf.variantsMD5
                ).match() }
            )
        }

        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
        }
    }


