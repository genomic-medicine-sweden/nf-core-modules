nextflow_workflow {

    name "Test Workflow ANNOTATE_CADD"
    script "../main.nf"
    config "./nextflow.config"
    workflow "ANNOTATE_CADD"

    tag "subworkflows"
    tag "subworkflows_genomicmedicinesweden"
    tag "subworkflows/annotate_cadd"

    setup {
        nfcoreInitialise("${launchDir}/library/")
        nfcoreInstall(
            "${launchDir}/library/",
            [
                "bcftools/annotate",
                "bcftools/view",
                "cadd",
                "gawk",
                "tabix/tabix",
            ]
        )
        nfcoreLink("${launchDir}/library/", "${baseDir}/modules/")
    }

    test("1 sample - stub") {
        options "-stub"
        // CADD is too big to run on GitHub runners, so every input is a mock input for the purpose of testing the workflow logic and not the actual annotation.
        when {
            workflow {
                """
                input[0] = channel.of([
                    [ id:'genome_fai' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.fai', checkIfExists: true)
                ])
                input[1] = channel.of([
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/vcf/NA12878.chr22.1X.vcf.gz', checkIfExists: true)
                ])
                input[2] = channel.of([
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/vcf/NA12878.chr22.1X.vcf.gz.csi', checkIfExists: true)
                ])
                input[3] = channel.of([
                    [ id:'cadd_header' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/tab/test_rnaseq_SJ.out.tab', checkIfExists: true)
                ])
                input[4] = channel.of([
                    [ id: 'cadd_resources' ],
                    file("$projectDir/tests/", checkIfExists: true)
                ])
                input[5] = channel.of([
                    [ id: 'cadd_prescored_indels' ],
                    file("$projectDir/docs/", checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
            )
        }

        cleanup {
            nfcoreUnlink("${launchDir}/library/", "${baseDir}/modules/nf-core")
        }
    }
}
